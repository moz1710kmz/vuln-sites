# .env.example — docker compose（コントロールパネル）運用の環境変数一覧
#
# このサイト群は docker compose で起動し、各検証サイトはパネル GUI から起動/停止する前提。

# ── ネットワーク ─────────────────────────────────────────────────────────
# ホスト側のバインドアドレス。0.0.0.0 で外部公開（EC2 等）
BIND_ADDR=127.0.0.1
# 外部公開時の接続元制限は Security Group / firewall などホスト側で行う。

# ── TLS ────────────────────────────────────────────────────────────────
# 0=HTTP（既定）、1=HTTPS（自己署名）
VULN_TLS=0
# 持ち込み証明書を使う場合のみ指定（未指定なら自動生成）
# TLS_CERT=certs/vuln.crt
# TLS_KEY=certs/vuln.key

# ── コントロールパネル ────────────────────────────────────────────────────
PANEL_USER=admin
PANEL_PASS=panel123
# ホスト側の公開ポート。Docker コンテナ内の待受は 8080 固定。
PANEL_PORT=8080

# ── 各サイトのポート ────────────────────────────────────────────────────
# ホスト側の公開ポート。Docker コンテナ内の待受は 8081-8084 固定。
BANK_APP_PORT=8081
EC_APP_PORT=8082
BOARD_APP_PORT=8083
GRAPHQL_APP_PORT=8084
